{
  "name": "simple-notify",
  "version": "0.1.1",
  "description": "opencode plugin for macOS session notifications",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "mkdir -p dist && bun build src/index.ts --target=node --outfile=dist/index.js",
    "prepare": "bun run build",
    "test": "bun test",
    "check": "bun run test && bun run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ShuKe365/simple-notify.git"
  },
  "keywords": [
    "opencode",
    "plugin",
    "notify"
  ],
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "1.15.10"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}